<!DOCTYPE html>
<html lang="{{settings.lang}}">

  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/main.css">
    <link rel="stylesheet" href="/features.css">
    <link rel="stylesheet" href="/openData.css">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700&family=Barlow+Condensed:wght@500;600;700;800&family=Barlow+Semi+Condensed:wght@600;700&display=swap" rel="stylesheet">
    <style>
      :root {
        --red: #C8102E; --red-dk: #9E0C24; --navy: #14213D; --navy-2: #1F3864; 
        --blue: #15457E; --blue-2: #1E5BAA; --amber: #F4B41A; --cyan: #1597B8; --green: #2E7D32;
        --ink: #1b1e28; --muted: #5c6273; --line: #e3e7ef; --paper: #fff; --mist: #f1f4f9; --gnav: #3c4250;
        --shadow: 0 1px 2px rgba(20,33,61,.05),0 10px 28px rgba(20,33,61,.08);
        --shadow-lg: 0 20px 54px rgba(20,33,61,.18);
      }
    </style>
    <script src="https://kit.fontawesome.com/06fd3ecd3e.js" crossorigin="anonymous"></script>
    <link rel="icon" type="/img/png" href="{{settings.icon}}">
    <title>{{seoMetas.title}}</title>
    <meta name="description" content="{{seoMetas.description}}">
    <meta name="keywords" content="seguridad vial, reportes, accidentes,carreteras">
    <meta name="author" content="Observatorio Nacional de Seguridad Vial">   
    
    <script async src="https://www.googletagmanager.com/gtag/js?id=UA-256137196-1"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'UA-256137196-1');
    </script>
  </head>

	<body>
		{{#if enabledNavigation}}
			{{> default/navigation}}
		{{/if}}

		{{{body}}}
		
		{{#if enabledFooter}}
			{{> default/footer}}
		{{/if}}
		
		{{#if enabledNavigation}}
			{{> default/suscribers-modal}}
		{{/if}}
		
		<div id="fb-root"></div>

		<!--Facebookk-->
		<script async defer src="https://connect.facebook.net/en_US/sdk.js#xfbml=1&version=v3.2"></script>
		<script src="/main.js"></script>
		<script src="/opendata.js"></script>
		<script src="/features.js"></script>

		
	</body>

</html>
