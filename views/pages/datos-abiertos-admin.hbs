<section class="rsp-navbar banner">
    <div class="d-flex justify-content-between">
        <div class="logo">
            <!--Cambiar la imagen-->
            <a class="navbar-brand" href="{{endpointRebase settings.url}}"><img class="logo-img" src="{{parseHttp settings.logo }}" alt="{{ settings.title }}"></a>
        </div>
        <div class="d-flex align-items-center mr-3">
            <div class="navbar-nav">
                <div class="nav-item"><a href="/datosabiertos-logout" style="color: white;" class="nav-link">Salir</a></div>
            </div>
        </div>
    </div>

</section>
<main class="container mt-5 mb-5">
    <div class="row">
        <div class="col-12">
            <div class="conf-blk">
                <h3 class="rsp-title ft-bold mb-4 text-center">Subir Archivos</h3>
                <form id="datos-abiertos-form" action="/datos-abiertos-admin" method="POST" class="needs-validation" enctype="multipart/form-data">
                    <div class="form-group row">
                        <label for="title" class="col-12 col-md-2 col-form-label">Título:</label>
                        <div class="col-12 col-md-10">
                            <input type="text" id="title" name="title" class="form-control">
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="description" class="col-12 col-md-2 col-form-label">Descripción:</label>
                        <div class="col-12 col-md-10">
                            <textarea type="text" id="description" name="description" class="form-control" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="author" class="col-12 col-md-2 col-form-label">Autor:</label>
                        <div class="col-12 col-md-10">
                            <input type="text" id="author" name="author" class="form-control">
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="category-1" class="col-12 col-md-2 col-form-label">Categoría 1:</label>
                        <div class="col-12 col-md-10">
                            <select class="form-control" name="category-1" id="category-1">
                            <option value="0">Ninguna</option>
                            {{#each categories}}
                                <option value="{{value}}">{{key}}</option>
                            {{/each}}
                            </select>
                        </div>                        
                    </div>
                    <div class="form-group row">
                        <label for="category-2" class="col-12 col-md-2 col-form-label">Categoría 2:</label>
                        <div class="col-12 col-md-10">
                            <select class="form-control" name="category-2" id="category-2">
                            <option value="0">Ninguna</option>
                            {{#each categories}}
                                <option value="{{value}}">{{key}}</option>
                            {{/each}}
                            </select>
                        </div>                        
                    </div>
                    <div class="form-group row">
                        <label for="category-3" class="col-12 col-md-2 col-form-label">Categoría 3:</label>
                        <div class="col-12 col-md-10">
                            <select class="form-control" name="category-3" id="category-3">
                            <option value="0">Ninguna</option>
                            {{#each categories}}
                                <option value="{{value}}">{{key}}</option>
                            {{/each}}
                            </select>
                        </div>                        
                    </div>
                    <div class="form-group row">
                        <label for="type" class="col-12 col-md-2 col-form-label">Tipo de Contenido:</label>
                        <div class="col-12 col-md-10">
                            <select class="form-control" name="type" id="type">
                            <option value="0">Ninguno</option>
                            {{#each types}}
                                <option value="{{value}}">{{key}}</option>
                            {{/each}}
                            </select>
                        </div>                        
                    </div>
                    <div class="custom-file mt-3 shadow-none">
                        <input type="file" name="excel-file" id="excel-file" class="custom-file-input shadow-none">
                        <label for="excel-file" class="custom-file-label shadow-none">Agregar archivo tipo EXCEL</label>
                    </div>
                    <div class="custom-file mt-5 shadow-none">
                        <input type="file" name="pdf-file" id="pdf-file" class="custom-file-input shadow-none">
                        <label for="pdf-file" class="custom-file-label shadow-none">Agregar archivo tipo PDF</label>
                    </div>
                    <div class="custom-file mt-5 shadow-none">
                        <input type="file" name="csv-file" id="csv-file" class="custom-file-input shadow-none">
                        <label for="csv-file" class="custom-file-label shadow-none">Agregar archivo tipo CSV</label>
                    </div>
                    <div class="form-group d-flex flex-row-reverse mt-5">
                         <button type="submit" class="btn btn-rsp ft-bold">
                            Enviar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>