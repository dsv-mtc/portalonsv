<section class="rsp-nye-section rsp-wrap">
  <div class="container">
    <div class="row">
      <div class="col-md-4">
        <h3 class="rsp-title ft-bold">
          Noticias
        </h3>
      </div>
      <div class="col-md-8 mx-auto">
        <div class="input-group">
          <input type="text" id="search-input" class="form-control main-search" placeholder="{{t lang "buscar"}}" >
          <div class="input-group-append">
            <span id="search-button" class="input-group-text search-input">
              <i class="fal fa-search"></i>
            </span>
          </div>
        </div>
      </div>
    </div>
    <div id="search-alert" class="alert alert-danger alert-dismissible fade hide" role="alert">
      {{t lang "no-results"}}
    </div>
    <div class="row" id="default">
      {{#each post}}
        {{#if @first}}
          {{> noticias-eventos/noticias-eventos-card-head lang=../lang}}
          {{else}}
            {{> noticias-eventos/noticias-eventos-card-body lang=../lang}}
        {{/if}}
      {{/each}}
      <style>
        .custom-pag-wrapper {
          gap: 8px;
        }
        .custom-pag-btn {
          width: 42px;
          height: 42px;
          border-radius: 50%;
          display: flex;
          align-items: center;
          justify-content: center;
          font-weight: bold;
          font-size: 17px;
          border: none;
          background: transparent;
          color: #4b5563;
          transition: all 0.3s ease;
          text-decoration: none;
          cursor: pointer;
        }
        .custom-pag-btn:hover {
          background-color: #f3f4f6;
          color: #1d3557;
        }
        .custom-pag-btn.active {
          background-color: #1d3557;
          color: white;
          box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        }
        .custom-pag-btn i {
          font-size: 20px;
        }
      </style>

      <div class="col-12 d-flex justify-content-center align-items-center mt-5 mb-4 custom-pag-wrapper">
        {{#if pagination}}
          
          <a href="#" class="custom-pag-btn active" aria-label="Página 1">1</a>
          <a href="#" class="custom-pag-btn" aria-label="Página 2">2</a>
          <a href="#" class="custom-pag-btn" aria-label="Página 3">3</a>
          <a href="#" class="custom-pag-btn" aria-label="Página 4">4</a>

          <a href="#" class="custom-pag-btn" aria-label="Siguiente página">
            <i class="fal fa-chevron-right"></i>
          </a>
          <a href="#" class="custom-pag-btn" aria-label="Última página">
            <i class="fal fa-chevron-double-right"></i>
          </a>

        {{/if}}
      </div>  
    </div>
    <div class="row" id="results-template">
      
    </div>                
  </div>
</section>