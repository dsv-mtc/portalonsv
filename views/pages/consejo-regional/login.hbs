<link rel="stylesheet" href="/consejo-regional/login.css">

<main class="consejo-regional">
	<div class="login card">
		<div class="card-body">
			{{#if info_login}}
				<div class="col-12">
					<div class="alert alert-danger alert-dismissible fade show" role="alert">
						<strong>{{info_login}}</strong> 
						<button type="button" class="close" data-dismiss="alert" aria-label="Close">
							<span aria-hidden="true">&times;</span>
						</button>
					</div>
				</div>
			{{/if}}
			<h5 class="card-title text-center">
				<img class="logo-img-open-data" src="/img/logo-datos.png" alt="{{ settings.title }}">
			</h5>
			<form action="/consejo-regional/login" method="POST">
				<div class="form-group">
					<label for="email" class="col-form-label">Usuario:</label>
					<div class="">
						<input 
							class="form-control" 
							type="email"
							id="email"
							name="email"
							placeholder="email@email.com"
						>
					</div>
				</div>
				<div class="form-group">
					<label for="password" class="col-form-label">Clave:</label>
					<div class="">
						<input 
							class="form-control" 
							type="password"
							id="password"
							name="password"
						>
					</div>
				</div>
				<div class="mt-5 d-flex justify-content-end ">
					<button type="submit" class="btn btn-rsp ft-bold">
						Ingresar
					</button>
				</div>
			</form>
		</div>
	</div>
</main>