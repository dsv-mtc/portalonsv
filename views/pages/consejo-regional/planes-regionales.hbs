<link rel="stylesheet" href="/consejo-regional/index.css">

<style>
	.table thead tr th {
		font-weight: bold; 
		vertical-align: middle;
		font-size: 1rem;
	}
	.table td {
		vertical-align: middle;
	}
</style>

<link href="/datatables/DataTables-1.13.4/css/dataTables.bootstrap4.min.css" rel="stylesheet"/>
<link href="/datatables/Buttons-2.3.6/css/buttons.bootstrap4.min.css" rel="stylesheet"/>
<link href="/datatables/KeyTable-2.8.2/css/keyTable.bootstrap4.min.css" rel="stylesheet"/>
<link href="/datatables/SearchPanes-2.1.2/css/searchPanes.bootstrap4.min.css" rel="stylesheet"/>
<link href="/datatables/StateRestore-1.2.2/css/stateRestore.bootstrap4.min.css" rel="stylesheet"/>
 
<script src="/datatables/jQuery-3.6.0/jquery-3.6.0.min.js"></script>
<script src="/datatables/DataTables-1.13.4/js/jquery.dataTables.min.js"></script>
<script src="/datatables/DataTables-1.13.4/js/dataTables.bootstrap4.min.js"></script>
<script src="/datatables/Buttons-2.3.6/js/dataTables.buttons.min.js"></script>
<script src="/datatables/Buttons-2.3.6/js/buttons.bootstrap4.min.js"></script>
<script src="/datatables/Buttons-2.3.6/js/buttons.colVis.min.js"></script>
<script src="/datatables/KeyTable-2.8.2/js/dataTables.keyTable.min.js"></script>
<script src="/datatables/SearchPanes-2.1.2/js/dataTables.searchPanes.min.js"></script>
<script src="/datatables/SearchPanes-2.1.2/js/searchPanes.bootstrap4.min.js"></script>
<script src="/datatables/StateRestore-1.2.2/js/dataTables.stateRestore.min.js"></script>
<script src="/datatables/StateRestore-1.2.2/js/stateRestore.bootstrap4.min.js"></script>

<script defer src="/consejo-regional/js/planes-regionales.js"></script>

<div class="consejo-regional">
	{{>consejo-regional/sidebar}}

	<main class="content container-fluid" id="crud">
		<h3 class="rsp-title ft-bold mb-5 text-center">
			Planes Regionales
		</h3>

		{{#if info_document}}
			{{#each info_document}}
				<div class="col-12">
					<div class="{{style}}" role="alert">
						<strong>{{message}}</strong> 
						<button type="button" class="close" data-dismiss="alert" aria-label="Close">
							<span aria-hidden="true">&times;</span>
						</button>
					</div>
				</div>
			{{/each}}
		{{/if}}

		<button 
			type="button" 
			class="btn btn-primary mb-5" 
			data-toggle="modal"
			data-target="#modalAgregar"
		>
			Crear plan regional <i class="ml-1 fas fa-folder-plus"></i>
		</button>

		<div class="table-responsive">
			<table class="table" id="data-table">
				<thead>
					<tr>
						<th scope="col">Titulo</th>
						<th scope="col">Descripcion</th>
						<th scope="col">PDF</th>
						<th scope="col">Excel</th>
						<th scope="col">CSV</th>
						<th scope="col">Fecha</th>
						<th scope="col">Estado</th>
						<th scope="col"></th>
					</tr>
				</thead>
				<tbody>
					{{#if hasResults}}
						{{#each planesRegionales}}
							<tr 
								data-id="{{id}}"
								data-titulo="{{titulo}}"
								data-descripcion="{{descripcion}}"
								data-id-region="{{idRegion}}"
								data-id-author="{{idAuthor}}"
								data-excel-file-url="{{excelFileUrl}}"
								data-pdf-file-url="{{pdfFileUrl}}"
								data-csv-file-url="{{csvFileUrl}}"
								data-fecha-creacion="{{fechaCreacionISOString}}"
								data-esta-activo="{{estaActivo}}"
							>
								<td style="width: 8%;">
									<span class="d-block" style="max-height: 50px;overflow: hidden;">
										{{titulo}}
									</span>
								</td>
								<td style="width: 15%;">
									<span class="d-block" style="max-height: 50px;overflow: hidden;">
										{{descripcion}}
									</span>
								</td>
								<td style="width: 400px">
									<span class="d-block" style="max-height: 50px;overflow: hidden;">
										{{excelFileUrl}}
									</span>
								</td>
								<td style="width: 400px">
									<span class="d-block" style="max-height: 50px;overflow: hidden;">
										{{pdfFileUrl}}
									</span>
								</td>
								<td style="width: 400px">
									<span class="d-block" style="max-height: 50px;overflow: hidden;">
										{{csvFileUrl}}
									</span>
								</td>
								<td class="text-truncate">{{fechaCreacionString}}</td>
								<td style="font-size: 1.25em; text-align:center;">
									<span class="badge badge-{{#if estaActivo}}primary{{else}}danger{{/if}}">
										{{#if estaActivo}}
											Activo
										{{else}}
											Inactivo
										{{/if}}
									</span>
								</td>
								<td>
									<div class="btn-group" role="group" aria-label="Basic example">
										<button 
											type="button" 
											class="btn btn-primary" 
											data-toggle="modal" 
											data-target="#modalEditar"
											style="padding: 5.5px 15px;"
										>
												<i class="fas fa-edit"></i>
										</button>
										<button 
											type="button" 
											class="btn btn-danger" 
											data-toggle="modal" 
											data-target="#modalEliminar"
											style="padding: 5.5px 15px;"
										>
											<i class="fas fa-trash-alt"></i>
										</button>
									</div>
								</td>
							</tr>
						{{/each}}
					{{else}}
						<tr>
							<td colspan="10" class="text-center">
								<h3 style="margin: .75em 0 1.25em; font-size:1rem; font-weight:bold!important;">
									No se encontraron resultados
								</h3>
							</td>
						</tr>
					{{/if}}
				</tbody>
			</table>
		</div>

		<div class="modal fade" id="modalAgregar" tabindex="-1" role="dialog" aria-labelledby="agregar" aria-hidden="true">
			<div class="modal-dialog modal-dialog-scrollable modal-dialog-centered" role="document">
				<form class="modal-content" id="formAgregar" class="needs-validation">
					<div class="modal-header">
						<h5 class="modal-title" id="modalAgregarLabel">Crear plan regional</h5>
						<button type="button" class="close" data-dismiss="modal" aria-label="Close">
							<span aria-hidden="true">&times;</span>
						</button>
					</div>

					<div class="modal-body">

						<div class="form-group row">
							<label for="new_titulo" class="col-auto col-md-2 col-form-label">
								*Titulo:
							</label>
							<div class="col-auto col-md-10">
								<input 
									type="text" 
									id="new_titulo"  
									name="titulo" 
									maxlength="2000" 
									placeholder="Ingrese el título"
									class="form-control"
									required
								>
							</div>
						</div>

						<div class="form-group row">
							<label for="new_descripcion" class="col-12 col-md-2 col-form-label">
								*Descripcion:
							</label>
							<div class="col-12 col-md-10">
								<textarea 
									type="text" 
									id="new_descripcion" 
									name="descripcion" 
									class="form-control" 
									maxlength="2000" 
									rows="6"
									required
								></textarea>
							</div>
						</div>

						<div class="form-group row">
							<label for="new_region" class="col-auto col-md-2 col-form-label">
								*Region:
							</label>
							<div class="col-auto col-md-10">
								<select class="form-control" name="idRegion" id="new_region" required>
									<option selected>Selecione una región</option>
									{{#each regiones}}
										<option value="{{id}}">{{value}}</option>
									{{/each}}
								</select>
								<small class="invalid-feedback">Debe seleccionar un región</small>
							</div>
						</div>

						<div class="custom-file mt-3">
							<div style="display: flex;">
								<input 
									id="new_excel-f" 
									readonly 
									type="text" 
									class="form-control input-color" 
									placeholder="Agregar archivo tipo Excel"
									onclick="new_loadFile('excel')"
								>
								<button onclick="new_loadFile('excel')" type="button"  onclick="" class="button-file">Cargar</button>
							</div>
							<input 
								type="file" 
								name="excel-file" 
								id="new_excel-file" 
								class="file-hide"
								accept="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
							>
						</div>

						<div class="custom-file mt-5">
							<div style="display: flex;">
								<input 
									id="new_pdf-f"
									readonly 
									type="text" 
									class="form-control input-color" 
									placeholder="Agregar archivo tipo PDF"
									onclick="new_loadFile('pdf')"
								>
								<button  onclick="new_loadFile('pdf')" type="button"  onclick="" class="button-file">Cargar</button>
							</div>
							<input 
								type="file"
								name="pdf-file"
								id="new_pdf-file"
								class="file-hide"
								accept="application/pdf"
							>
						</div>
						
						<div class="custom-file my-5">
							<div style="display: flex;">
								<input 
									id="new_csv-f" 
									readonly 
									type="text"
									class="form-control input-color" 
									placeholder="Agregar archivo tipo CSV"  
									onclick="new_loadFile('csv')"
								>
								<button  onclick="new_loadFile('csv')" type="button"  onclick="" class="button-file">Cargar</button>
							</div>
							<input  
								type="file" 
								name="csv-file" 
								id="new_csv-file" 
								class="file-hide" 
								accept=".csv"
							>
						</div>

						<div class="form-group row">
							<label for="new_fecha" class="col-auto col-md-2 col-form-label">
								*Fecha:
							</label>
							<div class="col-auto col-md-10">
								<input
									type="date"
									id="new_fecha"
									name="fechaCreacion"
									maxlength="2000"
									placeholder="Ingrese la fecha" 
									class="form-control"
									required
								>
							</div>
						</div>
						
						<div class="form-check">
							<input type="checkbox" class="form-check-input" id="new_estaActivo" name="estaActivo" checked >
							<label class="form-check-label" for="new_estaActivo">
								¿Está activo?
							</label>
						</div>

						<div style="margin-top: 20px;">
							<p style="color: #ee1d27;">*: {{#if secondary_navigation}}
									Required fields
								{{else}}
									Campos obligatorios
								{{/if}}</p>
						</div>

					</div>

					<div class="modal-footer">
						<button type="button" class="btn btn-secondary" data-dismiss="modal">
							{{#if secondary_navigation}}
								Cancel
							{{else}}
								Cancelar
							{{/if}}
						</button>
						<button type="submit" class="btn btn-primary" id="btnAgregar">
							{{#if secondary_navigation}}
								Add
							{{else}}
								Agregar
							{{/if}}
						</button>
					</div>
				</form>
			</div>

		</div>

		<div class="modal fade" id="modalEditar" tabindex="-1" role="dialog" aria-labelledby="editar" aria-hidden="true">
			<div class="modal-dialog modal-dialog-scrollable modal-dialog-centered" role="document">
				<form class="modal-content" id="formEditar" class="needs-validation">
					<div class="modal-header">
						<h5 class="modal-title" id="modalEditarLabel">Editar plan regional</h5>
						<button type="button" class="close" data-dismiss="modal" aria-label="Close">
							<span aria-hidden="true">&times;</span>
						</button>
					</div>

					<div class="modal-body">

						<div class="form-group row">
							<label for="titulo" class="col-auto col-md-2 col-form-label">
								*Titulo:
							</label>
							<div class="col-auto col-md-10">
								<input 
									type="text" 
									id="titulo"  
									name="titulo" 
									maxlength="2000" 
									placeholder="Ingrese el título"
									class="form-control"
									required
								>
							</div>
						</div>

						<div class="form-group row">
							<label for="descripcion" class="col-12 col-md-2 col-form-label">
								*Descripcion:
							</label>
							<div class="col-12 col-md-10">
								<textarea 
									type="text" 
									id="descripcion" 
									name="descripcion" 
									class="form-control" 
									maxlength="2000" 
									rows="6"
									required
								></textarea>
							</div>
						</div>

						<div class="form-group row">
							<label for="region" class="col-auto col-md-2 col-form-label">
								*Region:
							</label>
							<div class="col-auto col-md-10">
								<select class="form-control" name="idRegion" id="region" required>
									<option selected>Selecione una región</option>
									{{#each regiones}}
										<option value="{{id}}">{{value}}</option>
									{{/each}}
								</select>
								<small class="invalid-feedback">Debe seleccionar un región</small>
							</div>
						</div>

						<div class="custom-file mt-3">
							<div style="display: flex;">
								<input 
									id="excel-f" 
									name="excelFileName"
									readonly 
									type="text" 
									class="form-control input-color" 
									placeholder="Agregar archivo tipo Excel"
									onclick="loadFile('excel')"
								>
								<button onclick="loadFile('excel')" type="button"  onclick="" class="button-file">Cargar</button>
							</div>
							<input 
								type="file" 
								name="excel-file" 
								id="excel-file" 
								class="file-hide"
								accept="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
							>
						</div>

						<div class="custom-file mt-5">
							<div style="display: flex;">
								<input 
									id="pdf-f"
									name="pdfFileName"
									readonly 
									type="text" 
									class="form-control input-color" 
									placeholder="Agregar archivo tipo PDF"
									onclick="loadFile('pdf')"
								>
								<button  onclick="loadFile('pdf')" type="button"  onclick="" class="button-file">Cargar</button>
							</div>
							<input 
								type="file"
								name="pdf-file"
								id="pdf-file"
								class="file-hide"
								accept="application/pdf"
							>
						</div>
						
						<div class="custom-file my-5">
							<div style="display: flex;">
								<input 
									id="csv-f"
									name="csvFileName" 
									readonly 
									type="text"
									class="form-control input-color" 
									placeholder="Agregar archivo tipo CSV"  
									onclick="loadFile('csv')"
								>
								<button  onclick="loadFile('csv')" type="button"  onclick="" class="button-file">Cargar</button>
							</div>
							<input  
								type="file" 
								name="csv-file" 
								id="csv-file" 
								class="file-hide" 
								accept=".csv"
							>
						</div>

						<div class="form-group row">
							<label for="fechaCreacion" class="col-auto col-md-2 col-form-label">
								*Fecha:
							</label>
							<div class="col-auto col-md-10">
									<input
										type="date"
										id="fechaCreacion"
										name="fechaCreacion"
										maxlength="2000"
										placeholder="Ingrese la fecha" 
										class="form-control"
										required
									>
							</div>
						</div>

						<div class="form-check">
							<input type="checkbox" class="form-check-input" id="estaActivo" name="estaActivo" checked >
							<label class="form-check-label" for="estaActivo">
								¿Está activo?
							</label>
						</div>

						<div style="margin-top: 20px;">
							<p style="color: #ee1d27;">*: {{#if secondary_navigation}}
									Required fields
								{{else}}
									Campos obligatorios
								{{/if}}</p>
						</div>

					</div>
					<div class="modal-footer">
						<button type="button" class="btn btn-secondary" data-dismiss="modal">
							{{#if secondary_navigation}}
								Cancel
							{{else}}
								Cancelar
							{{/if}}
						</button>
						<button type="submit" class="btn btn-primary" id="btnEditar">
							{{#if secondary_navigation}}
								Edit
							{{else}}
								Editar
							{{/if}}
						</button>
					</div>
				</form>
			</div>

		</div>

		<div class="modal fade" id="modalEliminar" tabindex="-1" role="dialog" aria-labelledby="eliminarDatosAbiertos" aria-hidden="true">
			<div class="modal-dialog modal-dialog-centered" role="document">
				<form class="modal-content" id="formEliminarDatosAbiertos">
					<div class="modal-header">
						<h5 class="modal-title" id="modalEliminarLabel">Eliminar datos abiertos</h5>
						<button type="button" class="close" data-dismiss="modal" aria-label="Close">
							<span aria-hidden="true">&times;</span>
						</button>
					</div>
					<div class="modal-body">
						<p>Se eliminará esta información, ¿Está seguro?</p>
					</div>
					<div class="modal-footer">
						<button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
						<button type="submit" class="btn btn-danger" id="btnEliminar">Eliminar</button>
					</div>
				</form>
			</div>
		</div>

	</main>
</div>