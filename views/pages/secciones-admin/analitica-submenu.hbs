<script defer src="/admin/analitica-submenu.js"></script>

<style>
	.table thead tr th {
		font-weight: bold; 
		vertical-align: middle;
		font-size: 1rem;
	}
	.table td {
		vertical-align: middle;
	}
	.table td span {
		max-height: 50px;
		overflow: hidden;
	}
	.table td:has(span) {
		overflow-wrap: break-word;
		word-break: break-all;
	}
	.table td .btn {
		padding: 5.5px 15px;
	}
</style>

{{>admin/banner secondary_navigation=secondary_navigation}}
{{>admin/navigation secondary_navigation=secondary_navigation}}

<main class="container-fluid mt-3 mb-3" id="submenu-crud">
	<h3 class="rsp-title ft-bold mb-3 text-center">
		{{#if secondary_navigation}}
			Analytical - Submenu
		{{else}}
			Analítica - Submenu
		{{/if}}
	</h3>
	
	{{#if info_document}}
		{{#each info_document}}
			<div class="col-12">
				<div class="{{style}}" role="alert">
					<strong>{{message}}</strong> 
					<button type="button" class="close" data-dismiss="alert" aria-label="Close">
						<span aria-hidden="true">&times;</span>
					</button>
				</div>
			</div>
		{{/each}}
	{{/if}}

	<button 
		type="button" 
		class="btn btn-primary mb-3" 
		data-toggle="modal"
		data-target="#modalAgregar"
		style="padding: 5.5px 15px;"
	>
		Agregar
	</button>

	<div class="table-responsive">
		<table class="table" id="data-table">
			<thead>
				<tr>
					<th scope="col">Menu</th>
					<th scope="col">Submenu</th>
					<th scope="col">Ruta Bi</th>
					<th scope="col">Link Video</th>
					<th scope="col">Link PDF</th>
					<th scope="col">Imagen</th>
					<th scope="col">Estado</th>
					<th scope="col"></th>
				</tr>
			</thead>
			<tbody>
				{{#each submenu}}
					<tr 
						data-id="{{id}}"
						data-submenu="{{submenu}}"
						data-menuid="{{menu_id}}"
						data-rutabi="{{rutabi}}"
						data-linkvideo="{{linkvideo}}"
						data-linkpdf="{{linkpdf}}"
						data-imagen="{{imagen}}"
						data-estado="{{estado}}"
					>
						<td>{{menu}}</td>
						<td>{{submenu}}</td>
						<td style="width: 400px;">
							<span class="d-block">
								{{rutabi}}
							</span>
						</td>
						<td style="width: 400px;">
							<span class="d-block">
								{{linkvideo}}
							</span>
						</td>
						<td style="width: 400px;">
							<span class="d-block">
								{{linkpdf}}
							</span>
						</td>
						<td>{{imagen}}</td>
						<td style="vertical-align: middle;font-size: 1.25em; text-align:center;">
							<span class="badge badge-{{#if estado}}primary{{else}}danger{{/if}}">
								{{#if estado}}
									Activo
								{{else}}
									Inactivo
								{{/if}}
							</span>
						</td>
						<td>
							<div class="btn-group" role="group" aria-label="Basic example">
								<button type="button" class="btn btn-primary" data-toggle="modal" data-target="#modalEditar">
									<i class="fas fa-edit"></i>
								</button>
								<button type="button" class="btn btn-danger" data-toggle="modal" data-target="#modalEliminar">
									<i class="fas fa-trash-alt"></i>
								</button>
							</div>
						</td>
					</tr>
				{{/each}}
			</tbody>
		</table>
	</div>

	<div class="modal fade" id="modalAgregar" tabindex="-1" role="dialog" aria-labelledby="agregarSubmenu" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered" role="document">
			<form class="modal-content" id="formAgregarSubmenu" class="needs-validation">
				<div class="modal-header">
					<h5 class="modal-title" id="modalAgregarLabel">Agregar submenu</h5>
					<button type="button" class="close" data-dismiss="modal" aria-label="Close">
						<span aria-hidden="true">&times;</span>
					</button>
				</div>

				<div class="modal-body">

					<div class="form-group row">
						<label for="new_menu_id" class="col-auto col-md-2 col-form-label">
							*Menu:
						</label>
						<div class="col-auto col-md-10">
								<select name="menu_id" id="new_menu_id" class="form-control">
									<option selected>--Selecione una opcion--</option>
									{{#each menu}}
										<option value="{{id}}">{{descripcion}}</option>
									{{/each}}
								</select>
						</div>
					</div>
					
					<div class="form-group row">
						<label for="new_submenu" class="col-auto col-md-2 col-form-label">
							*Submenu:
						</label>
						<div class="col-auto col-md-10">
								<input 
									type="text" 
									id="new_submenu"  
									name="submenu" 
									maxlength="2000" 
									placeholder="Ingrese el submenu"
									class="form-control"
									required
									{{!-- pattern="\w*" --}}
								>
								<small class="invalid-feedback">
									{{#if secondary_navigation}} 
										You must enter text only.
									{{else}}
										Debe introducir sólo texto.
									{{/if}}
								</small>
						</div>
					</div>

					<div class="form-group row">
						<label for="new_rutabi" class="col-auto col-md-2 col-form-label">
							*Ruta Bi:
						</label>
						<div class="col-auto col-md-10">
								<input
									type="text"
									id="new_rutabi"
									name="rutabi"
									maxlength="2000"
									placeholder="Ingrese la ruta bi" 
									class="form-control"
									required
								>
								<small class="invalid-feedback">
									{{#if secondary_navigation}} 
										You must enter a valid url.
									{{else}}
										Debe introducir una url válida.
									{{/if}}
								</small>
						</div>
					</div>
					
					<div class="form-group row">
						<label for="new_linkvideo" class="col-auto col-md-2 col-form-label">
							*Link video:
						</label>
						<div class="col-auto col-md-10">
								<input
									type="text"
									id="new_linkvideo"
									name="linkvideo"
									maxlength="2000"
									placeholder="Ingrese el link video" 
									class="form-control"
									required
								>
								<small class="invalid-feedback">
									{{#if secondary_navigation}} 
										You must enter a valid url.
									{{else}}
										Debe introducir una url válida.
									{{/if}}
								</small>
						</div>
					</div>

					<div class="form-group row">
						<label for="new_linkpdf" class="col-auto col-md-2 col-form-label">
							*Link PDF:
						</label>
						<div class="col-auto col-md-10">
								<input
									type="text"
									id="new_linkpdf"
									name="linkpdf"
									maxlength="2000"
									placeholder="Ingrese el link pdf" 
									class="form-control"
									required
								>
								<small class="invalid-feedback">
									{{#if secondary_navigation}} 
										You must enter a valid url.
									{{else}}
										Debe introducir una url válida.
									{{/if}}
								</small>
						</div>
					</div>

					<div class="custom-file mt-3 mb-5">
						<div style="display: flex;">
							<input 
								id="new_img-f" 
								name="imgFileName"
								readonly 
								type="text" 
								class="form-control input-color" 
								placeholder="Agregar archivo tipo IMG"
								onclick="new_loadFile('img')"
							>
							<button onclick="new_loadFile('img')" type="button"  onclick="" class="button-file">Cargar</button>
						</div>
						<input 
							type="file" 
							name="img-file" 
							id="new_img-file" 
							class="file-hide"
							accept="image/*"
						>
					</div>

					<div class="form-check">
						<input class="form-check-input" type="checkbox" id="new_estado" name="estado">
						<label class="form-check-label" for="estado">
							Estado
						</label>
					</div>

					<div style="margin-top: 20px;">
						<p style="color: #ee1d27;">*: {{#if secondary_navigation}}
								Required fields
							{{else}}
								Campos obligatorios
							{{/if}}</p>
					</div>

				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-dismiss="modal">
						{{#if secondary_navigation}}
							Cancel
						{{else}}
							Cancelar
						{{/if}}
					</button>
					<button type="submit" class="btn btn-primary" id="btnAgregar">
						{{#if secondary_navigation}}
							Add
						{{else}}
							Agregar
						{{/if}}
					</button>
				</div>
			</form>
		</div>

	</div>

	<div class="modal fade" id="modalEditar" tabindex="-1" role="dialog" aria-labelledby="editarSubmenu" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered" role="document">
			<form class="modal-content" id="formEditarSubmenu" class="needs-validation">
				<div class="modal-header">
					<h5 class="modal-title" id="modalEditarLabel">Editar submenu</h5>
					<button type="button" class="close" data-dismiss="modal" aria-label="Close">
						<span aria-hidden="true">&times;</span>
					</button>
				</div>
				<div class="modal-body">

					<div class="form-group row">
						<label for="menu_id" class="col-auto col-md-2 col-form-label">
							*Menu:
						</label>
						<div class="col-auto col-md-10">
								<select name="menu_id" id="menu_id" class="form-control">
									<option value="">--Selecione una opcion--</option>
									{{#each menu}}
										<option value="{{id}}">{{descripcion}}</option>
									{{/each}}
								</select>
						</div>
					</div>
					
					<div class="form-group row">
						<label for="submenu" class="col-auto col-md-2 col-form-label">
							*Submenu:
						</label>
						<div class="col-auto col-md-10">
								<input 
									type="text" 
									id="submenu"  
									name="submenu" 
									maxlength="2000" 
									placeholder="Ingrese el submenu" 
									class="form-control"
									required
									{{!-- pattern="\w*" --}}
								>
								<small class="invalid-feedback">
									{{#if secondary_navigation}} 
										You must enter text only.
									{{else}}
										Debe introducir sólo texto.
									{{/if}}
								</small>
						</div>
					</div>

					<div class="form-group row">
						<label for="rutabi" class="col-auto col-md-2 col-form-label">
							*Ruta Bi:
						</label>
						<div class="col-auto col-md-10">
								<input
									type="text"
									id="rutabi"
									name="rutabi"
									maxlength="2000"
									placeholder="Ingrese la rutabi" 
									class="form-control"
									required
								>
								<small class="invalid-feedback">
									{{#if secondary_navigation}} 
										You must enter a valid url.
									{{else}}
										Debe introducir una url válida.
									{{/if}}
								</small>
						</div>
					</div>
					
					<div class="form-group row">
						<label for="linkvideo" class="col-auto col-md-2 col-form-label">
							*Link video:
						</label>
						<div class="col-auto col-md-10">
								<input
									type="text"
									id="linkvideo"
									name="linkvideo"
									maxlength="2000"
									placeholder="Ingrese el link video" 
									class="form-control"
									required
								>
								<small class="invalid-feedback">
									{{#if secondary_navigation}} 
										You must enter a valid url.
									{{else}}
										Debe introducir una url válida.
									{{/if}}
								</small>
						</div>
					</div>

					<div class="form-group row">
						<label for="linkpdf" class="col-auto col-md-2 col-form-label">
							*Link PDF:
						</label>
						<div class="col-auto col-md-10">
								<input
									type="text"
									id="linkpdf"
									name="linkpdf"
									maxlength="2000"
									placeholder="Ingrese el link pdf" 
									class="form-control"
									required
								>
								<small class="invalid-feedback">
									{{#if secondary_navigation}} 
										You must enter a valid url.
									{{else}}
										Debe introducir una url válida.
									{{/if}}
								</small>
						</div>
					</div>

					<div class="custom-file mt-3 mb-5">
						<div style="display: flex;">
							<input 
								id="img-f" 
								name="imgFileName"
								readonly 
								type="text" 
								class="form-control input-color" 
								placeholder="Agregar archivo tipo IMG"
								onclick="loadFile('img')"
							>
							<button onclick="loadFile('img')" type="button"  onclick="" class="button-file">Cargar</button>
						</div>
						<input 
							type="file" 
							name="img-file" 
							id="img-file" 
							class="file-hide"
							accept="image/*"
						>
					</div>

					<div class="form-check">
						<input 
							class="form-check-input" 
							type="checkbox"
							id="estado"
							name="estado"
						>
						<label class="form-check-label" for="estado">
							Estado
						</label>
					</div>

					<div style="margin-top: 20px;">
						<p style="color: #ee1d27;">*: {{#if secondary_navigation}}
								Required fields
							{{else}}
								Campos obligatorios
							{{/if}}</p>
					</div>

				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-dismiss="modal">
						{{#if secondary_navigation}}
							Cancel
						{{else}}
							Cancelar
						{{/if}}
					</button>
					<button type="submit" class="btn btn-primary" id="btnEditar">
						{{#if secondary_navigation}}
							Edit
						{{else}}
							Editar
						{{/if}}
					</button>
				</div>
			</form>
		</div>

	</div>

	<div class="modal fade" id="modalEliminar" tabindex="-1" role="dialog" aria-labelledby="eliminarSubmenu" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered" role="document">
			<form class="modal-content" id="formEliminarSubmenu">
				<div class="modal-header">
					<h5 class="modal-title" id="modalEliminarLabel">Eliminar submenu</h5>
					<button type="button" class="close" data-dismiss="modal" aria-label="Close">
						<span aria-hidden="true">&times;</span>
					</button>
				</div>
				<div class="modal-body">
					<p>Se eliminará un submenu, ¿Está seguro?</p>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
					<button type="submit" class="btn btn-danger" id="btnEliminar">Eliminar</button>
				</div>
			</form>
		</div>
	</div>

</main>