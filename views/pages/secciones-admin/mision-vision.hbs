<section class="rsp-navbar banner">
	<div class="d-flex justify-content-between">
		
		<div class="logo">
			<!--Cambiar la imagen-->
			<a class="navbar-brand" href="{{endpointRebase settings.url}}"><img class="logo-img-open-data" src="/img/logo-datos.png" alt="{{ settings.title }}"></a>
		</div>
		
		<div class="d-flex align-items-center mr-3">
			<div class="navbar-nav">
				<div class="nav-item">
					<a href="/administrador/logout" style="color: white;" class="nav-link">
						{{#if secondary_navigation}}
							Logout
						{{else}}
							Cerrar sesión
						{{/if}}
					</a>
				</div>
			</div>
		</div>

	</div>
</section>

{{>admin/navigation secondary_navigation=secondary_navigation}}

<main class="container mt-5 mb-5">
    <div class="row">
        <div class="col-12" id="sectionContainer">
            <h3 class="rsp-title ft-bold mb-4 text-center">MISION - VISION</h3>

						{{#if info_document}}
								{{#each info_document}}
										<div class="col-12">
												<div class="{{style}}" role="alert">
														<strong>{{message}}</strong> 
														<button type="button" class="close" data-dismiss="alert" aria-label="Close">
																<span aria-hidden="true">&times;</span>
														</button>
												</div>
										</div>
								{{/each}}
						{{/if}}

						<form id="datosabiertos-form" action="/administrador/mision-vision" method="POST" class="needs-validation" novalidate >

							<div class="form-group row">
								<label for="esDescripcion" class="col-12 col-md-2 col-form-label">*Definicion ONSV - Es:</label>
								<div class="col-12 col-md-10">
										<textarea 
											type="text" 
											id="esDescripcion" 
											name="esDescripcion" 
											placeholder="Máximo 10000 caracteres" 
											class="form-control" 
											maxlength="10000" 
											rows="18" 
											required
										>{{esDescripcion}}</textarea>
								
										<small class="invalid-feedback">
											Debe introducir una descripción y no puede iniciar con espacios en blanco
										</small>
								</div>
							</div>
								
								
							<div class="form-group row">
								<label for="esMision" class="col-12 col-md-2 col-form-label">*Mision - Es:</label>
								<div class="col-12 col-md-10">
										<textarea 
											type="text" 
											id="esMision" 
											name="esMision" 
											placeholder="Máximo 2000 caracteres" 
											class="form-control" 
											maxlength="2000" 
											rows="5" 
											required
										>{{esMision}}</textarea>
								
										<small class="invalid-feedback">
											Debe introducir una descripción y no puede iniciar con espacios en blanco
										</small>
								</div>
							</div>
								
								
							<div class="form-group row">
								<label for="esVision" class="col-12 col-md-2 col-form-label">*Vision - Es:</label>
								<div class="col-12 col-md-10">
										<textarea 
											type="text" 
											id="esVision" 
											name="esVision" 
											placeholder="Máximo 2000 caracteres" 
											class="form-control" 
											maxlength="2000" 
											rows="5" 
											required
										>{{esVision}}</textarea>
								
										<small class="invalid-feedback">
											Debe introducir una descripción y no puede iniciar con espacios en blanco
										</small>
								</div>
							</div>
							


							<div class="form-group row">
								<label for="enDescripcion" class="col-12 col-md-2 col-form-label">*ONSV Definition - En:</label>
								<div class="col-12 col-md-10">
										<textarea 
											type="text" 
											id="enDescripcion" 
											name="enDescripcion" 
											placeholder="Máximo 10000 caracteres" 
											class="form-control" 
											maxlength="10000" 
											rows="18" 
											required
										>{{enDescripcion}}</textarea>
								
										<small class="invalid-feedback">
											Debe introducir una descripción y no puede iniciar con espacios en blanco
										</small>
								</div>
							</div>
								
								
							<div class="form-group row">
								<label for="enMision" class="col-12 col-md-2 col-form-label">*Mission - En:</label>
								<div class="col-12 col-md-10">
										<textarea 
											type="text" 
											id="enMision" 
											name="enMision" 
											placeholder="Máximo 10000 caracteres" 
											class="form-control" 
											maxlength="10000" 
											rows="5" 
											required
										>{{enMision}}</textarea>
								
										<small class="invalid-feedback">
											Debe introducir una descripción y no puede iniciar con espacios en blanco
										</small>
								</div>
							</div>
								
								
							<div class="form-group row">
								<label for="enVision" class="col-12 col-md-2 col-form-label">*Vision - En:</label>
								<div class="col-12 col-md-10">
										<textarea 
											type="text" 
											id="enVision" 
											name="enVision" 
											placeholder="Máximo 10000 caracteres" 
											class="form-control" 
											maxlength="10000" 
											rows="5" 
											required
										>{{enVision}}</textarea>
								
										<small class="invalid-feedback">
											Debe introducir una descripción y no puede iniciar con espacios en blanco
										</small>
								</div>
							</div>

								<div style="margin-top: 20px;">
										<p style="color: #ee1d27;">*: Campos obligatorios</p>
								</div>
								<div class="form-group d-flex flex-row-reverse mt-5">
										<button type="submit" class="btn btn-rsp ft-bold">
												Enviar
										</button>
								</div>
						</form>
        </div>
    </div>
</main>