<script defer src="/admin/datos-abiertos-categorias.js"></script>

<style>
	.table th {
		font-weight: bold; 
		font-size: 1.25rem;
	}
	.table td {
		vertical-align: middle;
	}
	.table td .btn {
		padding: 5.5px 15px;
	}
</style>

{{>admin/banner secondary_navigation=secondary_navigation}}
{{>admin/navigation secondary_navigation=secondary_navigation}}

<main class="container-fluid mt-3 mb-3" id="datos-abiertos-categorias-crud">
	<h3 class="rsp-title ft-bold mb-3 text-center">
		Categorías de datos abiertos
	</h3>

	<div class="container">
		
		{{#if info_document}}
			{{#each info_document}}
				<div class="{{style}}" role="alert">
					<strong>{{message}}</strong> 
					<button type="button" class="close" data-dismiss="alert" aria-label="Close">
						<span aria-hidden="true">&times;</span>
					</button>
				</div>
			{{/each}}
		{{/if}}

		<button 
			type="button" 
			class="btn btn-primary mb-3" 
			data-toggle="modal"
			data-target="#modalAgregar"
			style="padding: 5.5px 15px;"
		>
			Agregar
		</button>
		<div class="table-responsive">
			<table class="table" id="data-table">
				<thead>
					<tr>
						<th scope="col" style="width: 50%;">Categoria</th>
						<th scope="col" style="width: 40%;">Ícono</th>
						<th scope="col" style="width: 10%;text-align:center;">Estado</th>
						<th scope="col"></th>
					</tr>
				</thead>
				<tbody>
					{{#each categorias}}
						<tr 
							data-id="{{id}}"
							data-value="{{value}}"
							data-icon="{{icon}}"
							data-esta-activo="{{estaActivo}}"
						>
							<td style="font-size: 1.25em;"> {{value}} </td>
							<td style="font-size: 1.25em;"> {{{icon}}} </td>
							<td style="font-size: 1.25em; text-align:center;">
								<span class="badge badge-{{#if estaActivo}}primary{{else}}danger{{/if}}">
									{{#if estaActivo}}
										Activo
									{{else}}
										Inactivo
									{{/if}}
								</span>
							</td>
							<td>
								<div class="text-truncate" role="group" aria-label="Basic example">
									<button 
										type="button" 
										class="btn btn-primary text-truncate" 
										data-toggle="modal" 
										data-target="#modalEditar"
									>
										<i class="fas fa-edit"></i> Editar
									</button>
									<button 
										type="button" 
										class="btn btn-danger text-truncate" 
										data-toggle="modal" 
										data-target="#modalEliminar"
									>
										<i class="fas fa-trash-alt"></i> Eliminar
									</button>
								</div>
							</td>
						</tr>
					{{/each}}
				</tbody>
			</table>
		</div>

	</div>
	
	<div class="modal fade" id="modalAgregar" tabindex="-1" role="dialog" aria-labelledby="agregar" aria-hidden="true">
		<div class="modal-dialog modal-dialog-scrollable modal-dialog-centered" role="document">
			<form class="modal-content" id="formAgregar" class="needs-validation">
				<div class="modal-header">
					<h5 class="modal-title" id="modalAgregarLabel">Agregar</h5>
					<button type="button" class="close" data-dismiss="modal" aria-label="Close">
						<span aria-hidden="true">&times;</span>
					</button>
				</div>

				<div class="modal-body">

					<div class="form-group row">
						<label for="new_value" class="col-auto col-md-2 col-form-label">
							*Nombre:
						</label>
						<div class="col-auto col-md-10">
							<input 
								type="text" 
								id="new_value"  
								name="new_value" 
								maxlength="2000" 
								placeholder="Ingrese el nombre de la categoria"
								class="form-control"
								required
							>
						</div>
					</div>

					<div class="custom-file mt-3 mb-5">
						<div style="display: flex;">
							<input 
								id="new_img-f" 
								name="new_existingImage"
								readonly 
								type="text" 
								class="form-control input-color" 
								placeholder="Agregar ícono tipo IMG"
								onclick="new_loadFile('img')"
								required
							>
							<button onclick="new_loadFile('img')" type="button"  onclick="" class="button-file">
								Cargar
							</button>
						</div>
						<input 
							type="file" 
							name="img-file" 
							id="new_img-file" 
							class="file-hide"
							accept="image/*"
						>
					</div>

					<div class="form-check">
						<input type="checkbox" class="form-check-input" id="new_estaActivo" checked >
						<label class="form-check-label" for="new_estaActivo" name="new_estaActivo">
							¿Está activo?
						</label>
					</div>

					<div style="margin-top: 20px;">
						<p style="color: #ee1d27;">
							*: Campos obligatorios
						</p>
					</div>

				</div>
				<div class="modal-footer">
					<button 
						type="button" 
						class="btn btn-secondary" 
						data-dismiss="modal"
					>
						Cancelar
					</button>
					<button 
						type="submit" 
						class="btn btn-primary" 
						id="btnAgregar"
					>
						Agregar
					</button>
				</div>
			</form>
		</div>

	</div>

	<div class="modal fade" id="modalEditar" tabindex="-1" role="dialog" aria-labelledby="editar" aria-hidden="true">
		<div class="modal-dialog modal-dialog-scrollable modal-dialog-centered" role="document">
			<form class="modal-content" id="formEditar" class="needs-validation">
				<div class="modal-header">
					<h5 class="modal-title" id="modalEditarLabel">Editar</h5>
					<button type="button" class="close" data-dismiss="modal" aria-label="Close">
						<span aria-hidden="true">&times;</span>
					</button>
				</div>

				<div class="modal-body">

					<div class="form-group row">
						<label for="value" class="col-auto col-md-2 col-form-label">
							*Nombre:
						</label>
						<div class="col-auto col-md-10">
							<input 
								type="text" 
								id="value"  
								name="value" 
								maxlength="2000" 
								placeholder="Ingrese el título"
								class="form-control"
								required
							>
						</div>
					</div>

					<div class="custom-file mt-3 mb-5">
						<div style="display: flex;">
							<input 
								id="img-f" 
								name="existingImage"
								readonly 
								type="text" 
								class="form-control input-color" 
								placeholder="Agregar ícono tipo IMG"
								onclick="loadFile('img')"
								required
							>
							<button onclick="loadFile('img')" type="button"  onclick="" class="button-file">
								Cargar
							</button>
						</div>
						<input 
							type="file" 
							name="img-file" 
							id="img-file" 
							class="file-hide"
							accept="image/*"
						>
					</div>

					<div class="form-check">
						<input type="checkbox" class="form-check-input" id="estaActivo">
						<label class="form-check-label" for="estaActivo" name="estaActivo">¿Está activo?</label>
					</div>

					<div style="margin-top: 20px;">
						<p style="color: #ee1d27;">
							*: Campos obligatorios
					</div>

				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-dismiss="modal">
						Cancelar
					</button>
					<button type="submit" class="btn btn-primary" id="btnEditar">
						Editar
					</button>
				</div>
			</form>
		</div>

	</div>

	<div class="modal fade" id="modalEliminar" tabindex="-1" role="dialog" aria-labelledby="eliminar" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered" role="document">
			<form class="modal-content" id="formEliminar">
				<div class="modal-header">
					<h5 class="modal-title" id="modalEliminarLabel">Eliminar categoría</h5>
					<button type="button" class="close" data-dismiss="modal" aria-label="Close">
						<span aria-hidden="true">&times;</span>
					</button>
				</div>
				<div class="modal-body">
					<p>Se eliminará esta información, ¿Está seguro?</p>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
					<button type="submit" class="btn btn-danger" id="btnEliminar">Eliminar</button>
				</div>
			</form>
		</div>
	</div>

</main>