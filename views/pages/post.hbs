<section class="rsp-vu-sec rsp-wrap">
    <div class="container container-post">
        <div class="row pt-5">
            <!--Contenido del post-->
            {{#post}}
                <div class="col-lg-8 col-md-7 vu-map-col">
                    <h3 class="rsp-title ft-bold mb-4 text-center">
                        {{title}}
                    </h3>
                    <div class="re-blk-post">
                        <div class="row">
                            <!--imagen principal-->
                            <div class="col-md-12">
                                <div class="rsp-nye-img post-img">
                                    <img class="post-img" src="{{parseHttp feature_image}}" alt="nye">
                                </div>
                            </div>
                            <!--Estructura del post -->
                            <div class="col-md-12">
                                <div class="rsp-nye-desc">
                                    <div class="rsp-pro-det pt-3 pb-1">
                                        <!--medatatos del post-->
                                        <div class="pd-desc ml-0">
                                                <div class="au"><i class="fas fa-user"></i> {{t "es" "Autor"}}: {{#primary_author}}{{ name }}{{/primary_author}} </div>
                                                <div class="tg"><i class="fas fa-tags"></i>
                                                    {{#each tags }}
                                                        <a href="{{endpointRebase2 url}}">{{slug}}</a>,
                                                        {{#if @last}}
                                                            <a href="{{endpointRebase2 url}}">{{slug}}</a>.
                                                        {{/if}} 
                                                    {{/each}}
                                                </div>
                                                <div class="cl"><i class="fas fa-calendar-alt"></i> {{parseDate created_at }} </div>
                                        </div>
                                    </div>
                                    <!--Contenido del post -->
                                    <main class="text-justify">
                                        {{{checkHtml html}}}
                                    </main>
                                    <div class="nye-link-blk">
                                        <div class="ny-btn">
                                            <a id="back" href="#" class="btn btn-rsp ft-bold">
                                                <i class="fal fa-long-arrow-left"></i>
                                            </a>
                                        </div>
                                        <div class="ny-link">
                                        <ul class="so-links">
                                            <li>
                                                <a href="https://www.facebook.com/sharer/sharer.php?u={{url}}" target="_blank"><i class="fab fa-facebook-f"></i></a>
                                            </li>
                                            <li>
                                                <a href="https://twitter.com/intent/tweet?text={{title}}&url={{url}}" target="_blank"><i class="fab fa-twitter"></i></a>
                                            </li>
                                            <li>
                                                <a href="whatsapp://send?text={{url}}" data-action="share/whatsapp/share"  target="_blank"><i class="fas fa-share-alt"></i></a>
                                            </li>
                                        </ul>
                                    </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {{/post}}
            <!--Contenido del sidebar-->
            <div class="col-lg-4 col-md-5 vu-list-col">
                <h6 class="rsp-title ft-bold text-center">
                    Artículos Relacionados
                </h6>
                <div class="vu-list">
                    <ul>
                        {{#each postsRelatives}}
                            {{> posts/post-card-sidebar}}
                        {{/each}}
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
