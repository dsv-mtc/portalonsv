<link rel="stylesheet" href="/css/publicaciones.css">

<script src="/js/publicaciones.js"></script>

<section class="publicaciones-section">

	<div class="filters">

		<form id="searchForm" method="GET">

			<div class="input-group mb-4">
				<input 
					type="text" 
					id="title" 
					name="title" 
					class="form-control main-search" 
					placeholder="{{t lang "buscar"}}"
					{{#if title}}
						value="{{title}}"
					{{/if}}
				>
				<div class="input-group-append">
					<button class="input-group-text search-input" type="submit">
						<i class="fal fa-search"></i>
					</button>
				</div>
			</div>

			<div class="form-group row">
				<label for="categoria" class="col-3 col-form-label">
					Categoría
				</label>
				<div class="col-9">
					<select name="categoria" id="categoria" class="form-control">
						<option {{#if categoria}} {{else}} selected {{/if}} value=''>Selecione una categoría</option>
						{{#each allTags}}
							<option 
								value="{{this.slug}}"
								{{#if this.estaSeleccionado}}
									selected
								{{/if}}
							>
								{{this.name}}
							</option>
						{{/each}}
					</select>
				</div>
			</div>

			<div class="form-group row">
				<label for="region" class="col-3 col-form-label">
					Región
				</label>
				<div class="col-9">
					<select name="region" id="region" class="form-control">
						<option {{#if region}} {{else}} selected {{/if}} value=''>Selecione una región</option>
						{{#each regiones}}
							<option 
								value="{{this.slug}}"
								{{#if this.estaSeleccionado}}
									selected
								{{/if}}
							>
								{{this.value}}
							</option>
						{{/each}}
					</select>
				</div>
			</div>

			<div class="form-group row">
				<label for="year" class="col-3 col-form-label">
					Año
				</label>
				<div class="col-9">
					<select name="year" id="year" class="form-control">
						<option {{#if year}} {{else}} selected {{/if}} value=''>Selecione un año</option>
						{{#each years}}
							<option 
								value="{{this.slug}}"
								{{#if this.estaSeleccionado}}
									selected
								{{/if}}
							>
								{{this.name}}
							</option>
						{{/each}}
					</select>
				</div>
			</div>

			<div class="d-flex justify-content-center " style="gap: 1rem;">
				<button class="ny-btn btn btn-rsp ft-bold" type="submit">
					<i class="fal fa-search"></i>
					Buscar
				</button>
				
				<button class="ny-btn btn btn-rsp ft-bold" id="clearButton">
					<i class="fas fa-broom"></i>
					Limpiar
				</button>
			</div>


		</form>

		{{>sidebar-widgets/subscribers lang=lang}}

	</div>

	<div class="results">
		{{#if hasResults}}
			{{#each posts}}
				{{>publicaciones/publicaciones-card-body lang=../lang}}
			{{/each}}

			{{#if pagination}}
        <style>
          .custom-pag-wrapper {
            gap: 8px;
          }
          .custom-pag-btn {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 17px;
            border: none;
            background: transparent;
            color: #4b5563;
            transition: all 0.3s ease;
            text-decoration: none;
            cursor: pointer;
          }
          .custom-pag-btn:hover {
            background-color: #f3f4f6;
            color: #1d3557;
          }
          .custom-pag-btn.active {
            background-color: #1d3557;
            color: white;
            box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
          }
          .custom-pag-btn i {
            font-size: 20px;
          }
        </style>

        <nav class="col-12 d-flex justify-content-center align-items-center mt-5 mb-4 custom-pag-wrapper">
          <a href="#" class="custom-pag-btn active" aria-label="Página 1">1</a>
          <a href="#" class="custom-pag-btn" aria-label="Página 2">2</a>
          <a href="#" class="custom-pag-btn" aria-label="Página 3">3</a>
          <a href="#" class="custom-pag-btn" aria-label="Página 4">4</a>

          <a href="#" class="custom-pag-btn" aria-label="Siguiente página">
            <i class="fal fa-chevron-right"></i>
          </a>
          <a href="#" class="custom-pag-btn" aria-label="Última página">
            <i class="fal fa-chevron-double-right"></i>
          </a>
        </nav>
        {{/if}}
		{{else}}
			<h3 style="margin: .75em 0 1.25em; font-size:1.25em; font-weight:bold!important;">
				No se encontraron resultados
			</h3>
		{{/if}}
	</div>

</section>