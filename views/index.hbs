  .hero .arrow { position: absolute; top: 50%; transform: translateY(-50%); z-index: 4; width: 44px; height: 44px; border-radius: 50%; background: rgba(255,255,255,.16); border: 1px solid rgba(255,255,255,.4); color: #fff; cursor: pointer; font-size: 20px; display: grid; place-items: center; transition: .2s; text-decoration: none; }
