  .sec-title { font-family: "Barlow Condensed", sans-serif; font-weight: 800; text-transform: uppercase; font-size: clamp(26px,3.4vw,42px); line-height: 1; color: var(--navy); letter-spacing: .005em; margin: 0; }
  .sec-head { display: flex; align-items: center; justify-content: space-between; gap: 14px; flex-wrap: wrap; margin-bottom: 26px; }
  .sec-head .more { font-family: "Barlow Semi Condensed", sans-serif; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; font-size: 13px; color: var(--blue-2); display: inline-flex; align-items: center; gap: 7px; background: none; border:none; padding: 0; cursor: pointer; transition: .2s; }
  .sec-head .more:hover { color: var(--red); gap: 11px; text-decoration: none; }

  /* HERO / SLIDER (Híbrido) */
  .hero { position: relative; background: var(--navy); overflow: hidden; }
  .slides.carousel-inner { height: clamp(420px,56vh,560px); }
  .hero .slide.carousel-item { height: 100%; border:none; }
  .hero .bg { position: absolute; inset: 0; background-size: cover; background-position: center; transform: scale(1.06); }
  .hero .active .bg { animation: kb 7s ease forwards; }
  @keyframes kb { to { transform: scale(1); } }
  .hero .veil { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(13,21,40,0) 48%, rgba(13,21,40,.5) 58%, rgba(13,21,40,.5) 100%); }
  
  .hero-in { position: absolute; inset:0; z-index: 2; width: 100%; max-width: var(--maxw); margin: 0 auto; padding: 0 24px; display: flex; align-items: center; justify-content: flex-end; }
  .hero-card { max-width: 480px; text-align: left; }
  .hero .kick { color: var(--amber); font-family: "Barlow Semi Condensed", sans-serif; font-weight: 700; text-transform: uppercase; letter-spacing: .2em; font-size: 14px; margin-bottom: 14px; opacity: 0; animation: rise .7s .15s forwards; }
  .hero h1 { color: #fff; font-family: "Barlow Condensed", sans-serif; font-size: clamp(26px,3.4vw,42px); line-height: 1.04; font-weight: 700; margin: 0; opacity: 0; animation: rise .7s .3s forwards; }
  .hero h1 em { color: var(--red); font-style: normal; }
  .hero p { color: #e7ecf6; font-family: "Barlow", sans-serif; font-size: clamp(15px,1.7vw,17px); max-width: 440px; margin-top: 16px; opacity: 0; animation: rise .7s .45s forwards; }
  
  .hero .btns { margin-top: 28px; display: flex; gap: 14px; flex-wrap: wrap; opacity: 0; animation: rise .7s .6s forwards; }
  .hero .btn-hero { font-family: "Barlow Semi Condensed", sans-serif; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; font-size: 15px; padding: 13px 24px; border-radius: 9px; cursor: pointer; border: 2px solid transparent; transition: .2s; display: inline-flex; gap: 9px; align-items: center; text-decoration: none; }
