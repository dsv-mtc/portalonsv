{{#if datosAbiertos}}
	{{#each datosAbiertos}}
		<div class="open_data_card">

			<svg width="32" height="32" viewBox="0 0 24 24">
				<path
					fill="none"
					stroke="currentColor"
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="2"
					d="m14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1l-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5"
				>
				</path>
			</svg>
		
			<div class="open_data_card_wrapper">
				<small class="open_data_date">
					Publicado el {{fecha}}
				</small>

				<h2>{{titulo}}</h2>
					
				<small class="categoria">
					<img src="{{iconCategoria}}" alt="icono" style="height: 16px; width: 16px">
					{{categoria}}
				</small>

				<p class="description">
					<svg width="18" height="18" viewBox="0 0 24 24">
						<path
								fill="currentColor"
								d="M16 2H8C4.691 2 2 4.691 2 8v13a1 1 0 0 0 1 1h13c3.309 0 6-2.691 6-6V8c0-3.309-2.691-6-6-6zm-2 13H7v-2h7v2zm3-4H7V9h10v2z"
						></path>
					</svg>
					{{descripcion}}
				</p>

				<div class="author">
					<svg width="18" height="18" viewBox="0 0 20 20">
						<path
							fill="currentColor"
							d="M10 2a4 4 0 1 0 0 8a4 4 0 0 0 0-8ZM7 6a3 3 0 1 1 6 0a3 3 0 0 1-6 0Zm-1.991 5A2.001 2.001 0 0 0 3 13c0 1.691.833 2.966 2.135 3.797c1.05.669 2.398 1.049 3.87 1.165c.01-.102.026-.205.052-.309l.17-.678c-1.413-.093-2.646-.442-3.554-1.022C4.623 15.283 4 14.31 4 13c0-.553.448-1 1.009-1h7.934l1-1H5.009Zm5.97 4.377l4.83-4.83a1.87 1.87 0 1 1 2.645 2.646l-4.83 4.829a2.197 2.197 0 0 1-1.02.578l-1.498.374a.89.89 0 0 1-1.079-1.078l.375-1.498a2.18 2.18 0 0 1 .578-1.02Z"
						>
						</path>
					</svg>
					Autor: {{autor}}
				</div>
				
				<div class="links">
					<a 
						href="{{excelfile}}" 
						target="_blank"
						class="{{#if hasExcel}}not_null{{else}}is_null{{/if}}"
					>
						<svg width="16" height="16" viewBox="0 0 24 24">
							<path
									fill="currentColor"
									d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6m1.8 18H14l-2-3.4l-2 3.4H8.2l2.9-4.5L8.2 11H10l2 3.4l2-3.4h1.8l-2.9 4.5l2.9 4.5M13 9V3.5L18.5 9H13Z"
							>
							</path>
						</svg>
						excel
					</a>

					<a
						href="{{pdffile}}"
						target="_blank"
						class="{{#if hasPdf}}not_null{{else}}is_null{{/if}}"
					>
						<svg width="16" height="16" viewBox="0 0 24 24">
							<path
									fill="currentColor"
									d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2m-9.5 8.5c0 .8-.7 1.5-1.5 1.5H7v2H5.5V9H8c.8 0 1.5.7 1.5 1.5v1m5 2c0 .8-.7 1.5-1.5 1.5h-2.5V9H13c.8 0 1.5.7 1.5 1.5v3m4-3H17v1h1.5V13H17v2h-1.5V9h3v1.5m-6.5 0h1v3h-1v-3m-5 0h1v1H7v-1Z"
							>
							</path>
						</svg>
						pdf
					</a>

					<a
						href="{{csvfile}}"
						target="_blank"
						class="{{#if hasCsv}}not_null{{else}}is_null{{/if}}"
					>
						<svg width="16" height="16" viewBox="0 0 256 256">
							<path
								fill="currentColor"
								d="m219.4 171.1l-20 48a8 8 0 0 1-14.8 0l-20-48a8 8 0 1 1 14.8-6.2l12.6 30.3l12.6-30.3a8 8 0 1 1 14.8 6.2ZM66 176a12.9 12.9 0 0 1 8.6 3.4a7.9 7.9 0 0 0 11.3-.6a8 8 0 0 0-.5-11.3A29.3 29.3 0 0 0 66 160c-16.5 0-30 14.4-30 32s13.5 32 30 32a29.3 29.3 0 0 0 19.4-7.5a8 8 0 0 0 .5-11.3a7.9 7.9 0 0 0-11.3-.6A12.9 12.9 0 0 1 66 208c-7.7 0-14-7.2-14-16s6.3-16 14-16Zm134-80h-48a8 8 0 0 1-8-8V40H56v88a8 8 0 0 1-16 0V40a16 16 0 0 1 16-16h96a8.1 8.1 0 0 1 5.7 2.3l55.9 56A7.8 7.8 0 0 1 216 88v40a8 8 0 0 1-16 0Zm-40-16h28.7L160 51.3Zm-30.3 103.8c-3.1-.8-8.6-2.3-9.7-3.6v-.2c0-3.3 2.4-5 7-5a18.4 18.4 0 0 1 10 3.2h-.1a8.3 8.3 0 0 0 5.1 1.8a8 8 0 0 0 8-8a7.6 7.6 0 0 0-2.9-6.1A33.4 33.4 0 0 0 127 159c-13.5 0-23 8.6-23 21s13 17 21.6 19.3c3.4.9 7 1.8 9.2 3.1s1.2 1 1.2 1.6s0 5-9 5a18.4 18.4 0 0 1-10-3.2h.1a8.3 8.3 0 0 0-5.1-1.8a8 8 0 0 0-8 8a7.6 7.6 0 0 0 2.9 6.1A33.4 33.4 0 0 0 127 225c15.6 0 25-7.9 25-21s-14-18-22.3-20.2Z"
							>
							</path>
						</svg>
						csv
					</a>

				</div>

			</div>
			
		</div>
	{{/each}}
{{/if}}