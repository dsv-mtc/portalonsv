<article class="card">
	<picture class="card-img">
		<a href="{{endpointPostParse (parseHttp url) lang }}">
			<img class="card-img-top" src="{{parseHttpImage feature_image}}" alt="nye">
		</a>
	</picture>
	<section class="card-body">
		
		<a href="{{endpointPostParse (parseHttp url) lang }}">
			<h6 class="card-title ft-bold publicaciones-tit">{{ title }}</h6>
		</a>

		<div class="created-at pd-desc">
			<div class="cl"><i class="fas fa-calendar-alt"></i> {{parseDate published_at }} </div>
		</div>

		<p class="publicaciones-det text-justify">
			{{excerpt}}
		</p>

		<div class="nav-links d-flex justify-content-around align-items-center flex-wrap gap-2">
			<div class="read-more ny-btn">
				<a href="{{endpointPostParse (parseHttp url) lang}}" class="btn btn-rsp ft-bold">
					{{t lang "leer más"}} 
					<i class="fal fa-long-arrow-right pl-2"></i>
				</a>
			</div>

			{{#if disableShareLinks}}
			{{else}}
				<div class="ny-link">
					<ul class="so-links">
						<li>
							<a href="https://www.facebook.com/sharer/sharer.php?u={{url}}" target="_blank"><i class="fab fa-facebook-f"></i></a>
						</li>
						<li>
							<a href="https://twitter.com/intent/tweet?text={{title}}&url={{url }}" target="_blank"><i class="fab fa-twitter"></i></a>
						</li>
						<li>
							<a href="whatsapp://send?text={{url}}" data-action="share/whatsapp/share"  target="_blank"><i class="fas fa-share-alt"></i></a>
						</li>
					</ul>
				</div>
			{{/if}}
		</div>

	</section>
</article>