<div class="col-md-6 col-lg-4 pb-5">
    <div class="rsp-res-blk">
        <div class="rsp-res-img">
            <a href="{{url}}">
                <img class="noticias-img" src="{{parseHttp feature_image}}" alt="imagen">
            </a>
        </div>
        <div class="rsp-res-blk-desc">
            <a href="{{ url }}">
                <h6 class="ft-bold noticias-tit"><a href="{{ url }}">{{ title}}</h6>
            </a>
        </div>
        <div class="rsp-pro-det">
            <div class="pd-desc">
                <div class="au"><i class="fas fa-user"></i> {{t "es" "Autor"}}: {{#primary_author}}{{ name }}{{/primary_author}} </div>
                <div class="tg"><i class="fas fa-tags"></i>
                    {{#each tags }}
                        <a href="{{url}}">{{slug}}</a>,
                        {{#if @last}}
                            <a href="{{url}}">{{slug}}</a>.
                        {{/if}} 
                    {{/each}}
                </div>
                <div class="cl"><i class="fas fa-calendar-alt"></i> {{parseDate created_at }}</div>
            </div>
        </div>
        <p class="noticias-det">
            {{ excerpt}}
        </p>
        <div class="nye-link-blk">
            <div class="ny-btn">
                <a href="{{url}}" class="btn btn-rsp ft-bold">
                    {{t "es" "leer más"}} <i class="fal fa-long-arrow-right pl-2"></i>
                </a>
            </div>
            <div class="ny-link">
                <ul class="so-links">
                    <li>
                        <a href="https://www.facebook.com/sharer/sharer.php?u={{url}}" target="_blank"><i class="fab fa-facebook-f"></i></a>
                    </li>
                    <li>
                        <a href="https://twitter.com/intent/tweet?text={{title}}&url={{url }}" target="_blank"><i class="fab fa-twitter"></i></a>
                    </li>
                    <li>
                        <a href="whatsapp://send?text={{url}}" data-action="share/whatsapp/share"  target="_blank"><i class="fas fa-share-alt"></i></a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>