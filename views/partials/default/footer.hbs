<footer id="footer">
	<div class="container">
		<div class="row">

			<div class="col-12 col-md-5 ft-mb m-ft-mar">
				<div class="ft-menu-blk mb-3">
					<h4 class="ft-menu text-white ft-bold">
						{{t lang "Contacto"}}
					</h4>
				</div>
				<ul class="ad-list with-ic">
					<li class="map">
						{{t lang "Direccion"}} :
						<span>
							{{footerData.direccion}}
						</span>
					</li>
					<li class="ph">
						{{t lang "Telefono"}} :
						<span>
							<a href="tel:{{footerData.telefono}}">
								{{footerData.telefono}}
							</a>
						</span>
					</li>
				</ul>
			</div>

			<div class="col-12 col-md-5 ft-mb m-ft-mar">
				<ul class="ad-list with-ic mt-2">
					<li class="mail">
						{{t lang "Correo"}} :
						<span>
							<a href="mailto:{{footerData.email}}">
								{{footerData.email}}
							</a>
						</span>
					</li>
					<li class="clock">
						<div>
							{{t lang "Horario"}}
						</div>
						<div>
							L - V  9:00 AM a 6:00 PM
						</div>
					</li>
				</ul>
			</div>

			<div class="col-12 col-md-2 ft-mmb">
				<div class="ft-menu-blk">
					<h4 class="ft-menu text-white ft-bold mb-3 ft-mb">
						{{t lang "Redes Sociales"}}
					</h4>
					<ul class="so-links">
						<li>
							<a href="https://www.facebook.com/onsvPE" target="_blank">
								<i class="fab fa-facebook-f"></i>
							</a>
						</li>
						<li>
							<a href="https://twitter.com/onsvPE" target="_blank">
								<i class="fab fa-twitter"></i>
							</a>
						</li>
						<li>
							<a
								href="https://www.youtube.com/channel/UCdNz5eyTZClohkpJgk4oa2Q"
								target="_blank"
							>
								<i class="fab fa-youtube"></i>
							</a>
						</li>
					</ul>
				</div>
			</div>

		</div>
		<div class="row cp">
			<div class="col-md-12">
				<div class="cp-soc text-white text-center">
					<p>
						Copyright &copy; {{footerData.year}} {{footerData.piePagina}}
					</p>
				</div>
			</div>
		</div>
	</div>
</footer>