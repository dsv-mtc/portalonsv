<!--================ Start header Top Area =================-->
<section class="rsp-navbar">
    <div class="container logo-container">
        <div class="row">
            <div class="col-md-6 col-8">
                <div class="logo">
                    <!--Cambiar la imagen-->
                    <a class="navbar-brand" href="{{endpointRebase settings.url}}"><img class="logo-img" src="{{parseHttp settings.logo }}" alt="{{ settings.title }}"></a>
                </div>
            </div>
            <div class="col-md-6 col-4">
                <div class="logo-sm">
                    <img src="/img/logo-sm.png" alt="{{ settings.title }}">
                </div>
            </div>
        </div>
        <div class="d-flex flex-row-reverse bd-highlight mt-md-n5 mt-n4">
            <nav class="navbar navbar-expand navbar-light">
                <ul class="navbar-nav mr-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/en/">EN </a>
                    </li>
                    <li class="nav-item">
                        <p class="nav-link">|</p>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/">ES</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
    <nav class="navbar navbar-expand-lg" id="mainNav">
        <div class="container-fluid">
            <button class="navbar-toggler mx-auto" type="button" data-toggle="collapse" data-target="#navbarResponsive" aria-controls="navbarResponsive" aria-expanded="false" aria-label="Toggle navigation">
                <span class="ham-icon"><i class="fal fa-bars"></i></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarResponsive">
                <ul class="navbar-nav nav-rsp">
                   {{#if secondary_navigation}}
                        {{#each settings.secondary_navigation}}
                            <li><a class="nav-link" href="{{this.url}}" target="{{setTarget this.label}}">{{this.label}}</a></li>
                        {{/each}}
                   {{else}}
                        {{#each settings.navigation}}
                            <li><a class="nav-link" href="{{this.url}}" target="{{setTarget this.label}}">{{this.label}}</a></li>
                        {{/each}}
                    {{/if}}
                </ul>
            </div>
        </div>
    </nav>
</section>
<!--================ End header top Area =================-->